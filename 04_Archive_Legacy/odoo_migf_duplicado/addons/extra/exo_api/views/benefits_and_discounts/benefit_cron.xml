<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_generate_pending_benefits" model="ir.cron">
            <field name="name">Generar Beneficios y Descuentos Pendientes</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_pending_benefits()</field>
            <field name="user_id" ref="base.user_root"/>

            <!-- Ejecutar cada 1 mes -->
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>

            <field name="numbercall">-1</field> <!-- Repetir infinitamente -->
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>

            <!-- Primera ejecución: próximo día 1 del mes a las 00:00 -->
            <field name="nextcall" eval="(DateTime.now().replace(day=1, hour=0, minute=0, second=0, microsecond=0) + relativedelta(months=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>
