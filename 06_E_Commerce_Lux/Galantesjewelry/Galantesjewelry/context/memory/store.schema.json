{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lead and Form Storage Schema",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "type": { "enum": ["appointment", "repair", "bridal", "contact"] },
    "customer": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" }
      },
      "required": ["name"]
    },
    "message": { "type": "string" },
    "dateRequested": { "type": "string", "format": "date-time" },
    "status": { "enum": ["new", "contacted", "confirmed", "archived"] }
  },
  "required": ["id", "type", "customer", "dateRequested", "status"]
}
