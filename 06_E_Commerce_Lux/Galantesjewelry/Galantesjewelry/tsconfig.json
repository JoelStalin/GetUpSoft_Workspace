{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/src/*": [
        "../src/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "../next-env.d.ts",
    "./**/*.js",
    "./**/*.ts",
    "./**/*.tsx",
    "../.next/types/**/*.ts",
    "../.next/dev/types/**/*.ts",
    "./**/*.mts",
    "../.next/dev/dev/types/**/*.ts"
  ]
}
