<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Jewelry Product Categories
         noupdate="0" means these records are re-applied on module upgrade.
         Do not change the id attributes – they are used as stable references.
    -->

    <!-- Root category -->
    <record id="product_category_jewelry" model="product.category">
        <field name="name">Jewelry</field>
    </record>

    <!-- First-level customer categories -->
    <record id="product_category_rings" model="product.category">
        <field name="name">Rings</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_bridal" model="product.category">
        <field name="name">Bridal</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_necklaces" model="product.category">
        <field name="name">Necklaces</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_bracelets" model="product.category">
        <field name="name">Bracelets</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_earrings" model="product.category">
        <field name="name">Earrings</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_nautical" model="product.category">
        <field name="name">Nautical Collection</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_custom" model="product.category">
        <field name="name">Custom Jewelry</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_gifts" model="product.category">
        <field name="name">Gifts</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_ready_to_ship" model="product.category">
        <field name="name">Ready to Ship</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>

    <record id="product_category_services" model="product.category">
        <field name="name">Services</field>
        <field name="parent_id" ref="product_category_jewelry"/>
    </record>
</odoo>
