<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_galantes_delivery" model="ir.ui.view">
        <field name="name">account.move.form.galantes.delivery</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_invoice_pdf_email"
                        string="Send Invoice PDF"
                        type="object"
                        class="oe_highlight"
                        invisible="move_type != 'out_invoice' or state != 'posted'"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Galantes Delivery" name="galantes_delivery">
                    <group string="Invoice Email Delivery">
                        <field name="galantes_invoice_email_sent" readonly="1"/>
                        <field name="galantes_invoice_email_sent_at" readonly="1"/>
                        <field name="galantes_invoice_email_message" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
