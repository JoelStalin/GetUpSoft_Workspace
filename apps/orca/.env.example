NVIDIA_API_KEY=replace-me
NVIDIA_API_KEY_KIMI=replace-me
NVIDIA_API_KEY_GEMMA=replace-me

# Local LLM inference (Ollama or vLLM)
# Set LOCAL_LLM_API_KEY to empty string or "ollama" for local endpoints
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_BASE_URL=http://getupsoft-lan:11434/v1
# To use local models instead of cloud, change:
# AI_ORCHESTRATOR_CONFIG_PATH=config/models.local-lan.json

# Rowboat integration
ROWBOAT_HOST=http://localhost:3000
ROWBOAT_PROJECT_ID=replace-me
ROWBOAT_API_KEY=replace-me
ROWBOAT_TIMEOUT_SECONDS=60

# Public Orca URL used inside downloadable client plugins
ORCA_PUBLIC_URL=https://orca.getupsoft.com
AI_PROVIDER_TIMEOUT_SECONDS=60

