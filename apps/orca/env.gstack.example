# GSTACK + ORCA shared configuration example
# Copy values into your environment or secret manager.

GSTACK_BASE_URL=https://api.gstack.ai
GSTACK_API_KEY=replace-me
GSTACK_DEFAULT_MODEL=gemini-2.5-pro
GSTACK_FALLBACK_MODELS=claude-sonnet-4,gpt-5-mini

ORCA_DEFAULT_PROVIDER=gstack
ORCA_DEFAULT_MODEL=gemini-2.5-pro
ORCA_ENABLE_MULTI_MODEL=true
