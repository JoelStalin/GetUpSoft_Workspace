[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060

[1001]
type=endpoint
transport=transport-udp
context=voicebot-internal
disallow=all
allow=ulaw,alaw
auth=1001-auth
aors=1001-aor
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[1001-auth]
type=auth
auth_type=userpass
username=1001
password=CHANGE_ME_EXTENSION_PASSWORD

[1001-aor]
type=aor
max_contacts=1
