# ORCA Workflow Editor - Environment Configuration
# Copy this file to .env.local and update values for your deployment

# Main local entrypoint
PORT=5173

# API Backend Configuration (NestJS)
VITE_API_URL=http://127.0.0.1:8788
API_URL=http://127.0.0.1:8788
VITE_ORCA_LIVE_API=true

# Odoo ERP Configuration
VITE_ODOO_URL=http://127.0.0.1:8069
VITE_ODOO_DB=odoo
VITE_ODOO_USER=admin
VITE_ODOO_PASSWORD=admin
ODOO_URL=http://127.0.0.1:8069

# Development Environment
VITE_MODE=development
VITE_ENV=development
VITE_DEBUG=false

# Production references
# VITE_API_URL=https://api.getupsoft.com
# API_URL=https://api.getupsoft.com
# VITE_ODOO_URL=https://odoo.getupsoft.com
# ODOO_URL=https://odoo.getupsoft.com
# VITE_ORCA_PUBLIC_URL=https://orca.getupsoft.com
