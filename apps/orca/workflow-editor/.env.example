# ORCA Workflow Editor - Environment Configuration
# Copy this file to .env and update values for your deployment

# Server Configuration
PORT=3000

# API Backend Configuration (NestJS)
VITE_API_URL=http://localhost:8015
API_URL=http://localhost:8015

# Odoo ERP Configuration
VITE_ODOO_URL=http://localhost:8069
VITE_ODOO_DB=odoo
VITE_ODOO_USER=admin
VITE_ODOO_PASSWORD=admin
ODOO_URL=http://localhost:8069

# Development Environment
VITE_ENV=development
VITE_DEBUG=false

# Production URLs (uncomment for production deployment)
# VITE_API_URL=https://api.getupsoft.com
# API_URL=https://api.getupsoft.com
# VITE_ODOO_URL=https://odoo.getupsoft.com
# ODOO_URL=https://odoo.getupsoft.com
