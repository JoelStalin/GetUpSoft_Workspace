# ORCA Workflow Editor - Environment Variables
# Copy this file to .env.local and fill in your API keys

# NVIDIA Models Integration
# Get API key from: https://build.nvidia.com/
VITE_NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenAI Models Integration
# Get API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Models Integration
# Get API key from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Logging and debugging
VITE_API_LOG_LEVEL=debug
VITE_ENABLE_COST_TRACKING=true

# Rate limiting (requests per minute)
VITE_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# API timeout in milliseconds
VITE_API_TIMEOUT_MS=30000
