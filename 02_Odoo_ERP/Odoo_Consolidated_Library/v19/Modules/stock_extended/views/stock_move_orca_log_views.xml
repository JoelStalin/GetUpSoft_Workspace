<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="stock_move_orca_log_view_tree" model="ir.ui.view">
            <field name="name">stock.move.orca.log.tree</field>
            <field name="model">orca.stock.move.log</field>
            <field name="arch" type="xml">
                <tree string="Stock Move ORCA Logs" decoration-danger="action=='unlink'">
                    <field name="date" />
                    <field name="user_id" />
                    <field name="action" />
                    <field name="product_code" />
                    <field name="quantity_moved" />
                    <field name="move_state" />
                    <field name="orca_synced" decoration-success="orca_synced" />
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="stock_move_orca_log_view_form" model="ir.ui.view">
            <field name="name">stock.move.orca.log.form</field>
            <field name="model">orca.stock.move.log</field>
            <field name="arch" type="xml">
                <form string="Stock Move ORCA Log">
                    <sheet>
                        <group>
                            <group>
                                <field name="date" />
                                <field name="user_id" />
                                <field name="action" />
                                <field name="tier" />
                            </group>
                            <group>
                                <field name="product_code" />
                                <field name="move_state" />
                                <field name="quantity_moved" />
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="product_name" />
                                <field name="origin_location" />
                                <field name="destination_location" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Captured Data">
                                <group>
                                    <field name="module_name" />
                                    <field name="model_name" />
                                    <field name="record_id" />
                                </group>
                            </page>
                            <page string="Before Values">
                                <field name="before_values" widget="ace" options="{'mode': 'json'}" />
                            </page>
                            <page string="After Values">
                                <field name="after_values" widget="ace" options="{'mode': 'json'}" />
                            </page>
                            <page string="ORCA Sync">
                                <group>
                                    <field name="orca_synced" />
                                    <field name="orca_request_id" attrs="{'invisible': [('orca_synced', '=', False)]}" />
                                    <field name="orca_sync_error" attrs="{'invisible': [('orca_sync_error', '=', False)]}" />
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="stock_move_orca_log_view_search" model="ir.ui.view">
            <field name="name">stock.move.orca.log.search</field>
            <field name="model">orca.stock.move.log</field>
            <field name="arch" type="xml">
                <search string="Stock Move ORCA Logs">
                    <field name="date" />
                    <field name="user_id" />
                    <field name="action" />
                    <field name="product_code" />
                    <filter string="Created" name="filter_create" domain="[('action', '=', 'create')]" />
                    <filter string="Written" name="filter_write" domain="[('action', '=', 'write')]" />
                    <filter string="Deleted" name="filter_delete" domain="[('action', '=', 'unlink')]" />
                    <filter string="Not Synced" name="filter_not_synced" domain="[('orca_synced', '=', False)]" />
                    <filter string="Synced" name="filter_synced" domain="[('orca_synced', '=', True)]" />
                    <group string="Group By">
                        <filter string="Action" name="group_action" context="{'group_by': 'action'}" />
                        <filter string="User" name="group_user" context="{'group_by': 'user_id'}" />
                        <filter string="Move State" name="group_state" context="{'group_by': 'move_state'}" />
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="stock_move_orca_log_action" model="ir.actions.act_window">
            <field name="name">Stock Move ORCA Logs</field>
            <field name="res_model">stock.move.orca.log</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="stock_move_orca_log_view_tree" />
            <field name="search_view_id" ref="stock_move_orca_log_view_search" />
            <field name="domain">[]</field>
            <field name="context">{}</field>
        </record>

        <!-- Menu Item -->
        <menuitem
            id="stock_move_orca_log_menu"
            parent="stock.menu_stock_root"
            action="stock_move_orca_log_action"
            sequence="99"
            groups="stock.group_stock_manager"
        />
    </data>
</odoo>
