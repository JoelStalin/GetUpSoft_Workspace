<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- E-Commerce Order ORCA Log List View -->
    <record id="view_orca_ecommerce_order_log_tree" model="ir.ui.view">
        <field name="name">orca.ecommerce.order.log.list</field>
        <field name="model">orca.ecommerce.order.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="order_reference"/>
                <field name="customer_email"/>
                <field name="order_status"/>
                <field name="order_total"/>
            </tree>
        </field>
    </record>

    <!-- E-Commerce Order ORCA Log Form View -->
    <record id="view_orca_ecommerce_order_log_form" model="ir.ui.view">
        <field name="name">orca.ecommerce.order.log.form</field>
        <field name="model">orca.ecommerce.order.log</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Log Metadata">
                        <field name="module_name"/>
                        <field name="model_name"/>
                        <field name="record_id"/>
                        <field name="action"/>
                        <field name="date"/>
                        <field name="user_id"/>
                    </group>
                    <group string="Order Details">
                        <field name="order_reference"/>
                        <field name="customer_email"/>
                        <field name="order_status"/>
                        <field name="order_date"/>
                        <field name="order_total"/>
                        <field name="item_count"/>
                    </group>
                    <group string="Audit Data">
                        <field name="before_values" widget="ace"/>
                        <field name="after_values" widget="ace"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_orca_website_sale_logs" name="ORCA Logs" parent="website.menu_website_config"/>

    <menuitem id="menu_orca_ecommerce_order_log" name="E-Commerce Orders"
              parent="menu_orca_website_sale_logs"
              action="action_view_orca_ecommerce_order_log"/>

    <!-- Actions -->
    <act_window id="action_view_orca_ecommerce_order_log"
                name="E-Commerce Order ORCA Logs"
                res_model="orca.ecommerce.order.log"
                view_mode="tree,form"/>
</odoo>
