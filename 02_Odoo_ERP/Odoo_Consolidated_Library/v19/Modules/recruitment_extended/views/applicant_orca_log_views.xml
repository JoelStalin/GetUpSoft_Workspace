<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Applicant ORCA Log List View -->
    <record id="view_orca_applicant_log_tree" model="ir.ui.view">
        <field name="name">orca.applicant.log.list</field>
        <field name="model">orca.applicant.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="applicant_name"/>
                <field name="applicant_email"/>
                <field name="job_position"/>
                <field name="stage_name"/>
                <field name="rating"/>
            </tree>
        </field>
    </record>

    <!-- Applicant ORCA Log Form View -->
    <record id="view_orca_applicant_log_form" model="ir.ui.view">
        <field name="name">orca.applicant.log.form</field>
        <field name="model">orca.applicant.log</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Log Metadata">
                        <field name="module_name"/>
                        <field name="model_name"/>
                        <field name="record_id"/>
                        <field name="action"/>
                        <field name="date"/>
                        <field name="user_id"/>
                    </group>
                    <group string="Applicant Details">
                        <field name="applicant_name"/>
                        <field name="applicant_email"/>
                        <field name="phone"/>
                        <field name="job_position"/>
                        <field name="department_name"/>
                        <field name="stage_name"/>
                        <field name="source"/>
                        <field name="rating"/>
                    </group>
                    <group string="Audit Data">
                        <field name="before_values" widget="ace"/>
                        <field name="after_values" widget="ace"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_orca_recruitment_logs" name="ORCA Logs" parent="hr_recruitment.menu_hr_recruitment_root"/>

    <menuitem id="menu_orca_applicant_log" name="Applicant Logs"
              parent="menu_orca_recruitment_logs"
              action="action_view_orca_applicant_log"/>

    <!-- Actions -->
    <act_window id="action_view_orca_applicant_log"
                name="Applicant ORCA Logs"
                res_model="orca.applicant.log"
                view_mode="tree,form"/>
</odoo>
