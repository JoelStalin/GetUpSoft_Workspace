<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Manufacturing Order ORCA Log List View -->
    <record id="view_orca_manufacturing_order_log_tree" model="ir.ui.view">
        <field name="name">orca.manufacturing.order.log.list</field>
        <field name="model">orca.manufacturing.order.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="mo_reference"/>
                <field name="product_name"/>
                <field name="mo_status"/>
                <field name="quantity_to_produce"/>
            </tree>
        </field>
    </record>

    <!-- Manufacturing Order ORCA Log Form View -->
    <record id="view_orca_manufacturing_order_log_form" model="ir.ui.view">
        <field name="name">orca.manufacturing.order.log.form</field>
        <field name="model">orca.manufacturing.order.log</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Log Metadata">
                        <field name="module_name"/>
                        <field name="model_name"/>
                        <field name="record_id"/>
                        <field name="action"/>
                        <field name="date"/>
                        <field name="user_id"/>
                    </group>
                    <group string="Manufacturing Order Details">
                        <field name="mo_reference"/>
                        <field name="product_name"/>
                        <field name="mo_status"/>
                        <field name="quantity_to_produce"/>
                        <field name="quantity_produced"/>
                        <field name="bom_id"/>
                    </group>
                    <group string="Audit Data">
                        <field name="before_values" widget="ace"/>
                        <field name="after_values" widget="ace"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_orca_mrp_logs" name="ORCA Logs" parent="mrp.menu_mrp_config"/>

    <menuitem id="menu_orca_manufacturing_order_log" name="Manufacturing Orders"
              parent="menu_orca_mrp_logs"
              action="action_view_orca_manufacturing_order_log"/>

    <!-- Actions -->
    <act_window id="action_view_orca_manufacturing_order_log"
                name="Manufacturing Order ORCA Logs"
                res_model="orca.manufacturing.order.log"
                view_mode="tree,form"/>
</odoo>
