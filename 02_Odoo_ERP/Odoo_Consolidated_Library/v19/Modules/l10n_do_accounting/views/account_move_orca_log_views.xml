<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View: Account Move ORCA Logs -->
    <record id="account_move_orca_log_view_tree" model="ir.ui.view">
        <field name="name">orca.l10n.do.accounting.move.log.tree</field>
        <field name="model">orca.l10n.do.accounting.move.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date" widget="date" />
                <field name="action" />
                <field name="record_id" />
                <field name="encf" />
                <field name="document_type" />
                <field name="user_id" />
                <field name="orca_synced" widget="boolean" />
                <field name="easycount_synced" widget="boolean" />
            </tree>
        </field>
    </record>

    <!-- Form View: Account Move ORCA Log Details -->
    <record id="account_move_orca_log_view_form" model="ir.ui.view">
        <field name="name">orca.l10n.do.accounting.move.log.form</field>
        <field name="model">orca.l10n.do.accounting.move.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="action" />
                            <span> — Invoice </span>
                            <field name="record_id" />
                            <span> (</span>
                            <field name="encf" />
                            <span>)</span>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="record_id" readonly="1" />
                            <field name="action" readonly="1" />
                            <field name="user_id" readonly="1" />
                        </group>
                        <group>
                            <field name="date" readonly="1" />
                            <field name="module_name" readonly="1" />
                            <field name="model_name" readonly="1" />
                        </group>
                    </group>

                    <group string="Fiscal Information">
                        <group>
                            <field name="encf" readonly="1" />
                            <field name="document_type" readonly="1" />
                            <field name="fiscal_state" readonly="1" />
                        </group>
                        <group>
                            <field name="dgii_uuid" readonly="1" />
                        </group>
                    </group>

                    <group string="Changes">
                        <field name="before_values" widget="text" readonly="1" />
                        <field name="after_values" widget="text" readonly="1" />
                    </group>

                    <group string="ORCA Sync Status">
                        <group>
                            <field name="orca_synced" readonly="1" />
                            <field name="orca_sync_date" readonly="1" />
                            <field name="orca_request_id" readonly="1" />
                        </group>
                        <group>
                            <field name="orca_sync_error" readonly="1" nolabel="1" />
                        </group>
                    </group>

                    <group string="EasyCount Sync Status">
                        <group>
                            <field name="easycount_synced" readonly="1" />
                            <field name="easycount_sync_date" readonly="1" />
                            <field name="easycount_attempt_count" readonly="1" />
                        </group>
                        <group>
                            <field name="easycount_sync_error" readonly="1" nolabel="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View: Account Move ORCA Log Filters -->
    <record id="account_move_orca_log_view_search" model="ir.ui.view">
        <field name="name">orca.l10n.do.accounting.move.log.search</field>
        <field name="model">orca.l10n.do.accounting.move.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="record_id" />
                <field name="encf" />
                <field name="document_type" />
                <field name="user_id" />
                <field name="date" />

                <filter name="filter_created" string="Created" domain="[('action', '=', 'create')]" />
                <filter name="filter_modified" string="Modified" domain="[('action', '=', 'write')]" />
                <filter name="filter_deleted" string="Deleted" domain="[('action', '=', 'unlink')]" />

                <separator />

                <filter name="filter_orca_pending" string="ORCA Pending" domain="[('orca_synced', '=', False)]" />
                <filter name="filter_orca_synced" string="ORCA Synced" domain="[('orca_synced', '=', True)]" />

                <separator />

                <filter name="filter_easycount_pending" string="EasyCount Pending" domain="[('easycount_synced', '=', False)]" />
                <filter name="filter_easycount_synced" string="EasyCount Synced" domain="[('easycount_synced', '=', True)]" />

                <separator />

                <filter name="filter_today" string="Today" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-%d')), ('date', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d'))]" />
                <filter name="filter_this_week" string="This Week" domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]" />
                <filter name="filter_this_month" string="This Month" domain="[('date', '&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d'))]" />

                <group expand="0" string="Group By">
                    <filter name="group_by_action" string="Action" domain="[]" context="{'group_by': 'action'}" />
                    <filter name="group_by_document_type" string="Document Type" domain="[]" context="{'group_by': 'document_type'}" />
                    <filter name="group_by_user" string="User" domain="[]" context="{'group_by': 'user_id'}" />
                    <filter name="group_by_date" string="Date" domain="[]" context="{'group_by': 'date:day'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="account_move_orca_log_action" model="ir.actions.act_window">
        <field name="name">Account Move ORCA Logs</field>
        <field name="res_model">orca.l10n.do.accounting.move.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="account_move_orca_log_view_search" />
        <field name="help">ORCA audit logs for invoice operations. Use filters to find specific fiscal events.</field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="account_move_orca_log_menu"
        name="Account Move Audit Logs"
        parent="account.menu_finance_entries"
        action="account_move_orca_log_action"
        sequence="100"
    />
</odoo>
