<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_orca_ecommerce_log_tree" model="ir.ui.view">
            <field name="name">Ecommerce ORCA Log Tree</field>
            <field name="model">orca.ecommerce.log</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="date"/>
                    <field name="user_id"/>
                    <field name="action"/>
                    <field name="product_name"/>
                    <field name="product_sku"/>
                    <field name="product_price"/>
                    <field name="is_ecommerce"/>
                </tree>
            </field>
        </record>

        <record id="view_orca_ecommerce_log_form" model="ir.ui.view">
            <field name="name">Ecommerce ORCA Log Form</field>
            <field name="model">orca.ecommerce.log</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group string="Log Metadata">
                                <field name="date"/>
                                <field name="user_id"/>
                                <field name="action"/>
                            </group>
                            <group string="Product Details">
                                <field name="product_name"/>
                                <field name="product_sku"/>
                                <field name="product_price"/>
                                <field name="is_ecommerce"/>
                                <field name="category_name"/>
                                <field name="purchase_count"/>
                            </group>
                        </group>
                        <group string="Audit Data">
                            <field name="before_values" widget="ace" options="{'mode': 'json'}" nolabel="1"/>
                            <field name="after_values" widget="ace" options="{'mode': 'json'}" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_orca_ecommerce_log_search" model="ir.ui.view">
            <field name="name">Ecommerce ORCA Log Search</field>
            <field name="model">orca.ecommerce.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="product_name" string="Product Name"/>
                    <field name="user_id"/>
                    <field name="action"/>
                    <filter name="ecommerce" string="Ecommerce Available" domain="[('is_ecommerce', '=', True)]"/>
                    <separator/>
                    <filter name="today" string="Today" domain="[('date', '>=', context_today().strftime('%Y-%m-%d')), ('date', '&lt;', (context_today() + timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_date" string="Date" context="{'group_by': 'date'}"/>
                        <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                        <filter name="group_action" string="Action" context="{'group_by': 'action'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_orca_ecommerce_log" model="ir.actions.act_window">
            <field name="name">Ecommerce ORCA Logs</field>
            <field name="res_model">orca.ecommerce.log</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No audit logs found.
                </p>
            </field>
        </record>

        <menuitem id="menu_orca_ecommerce_log" name="Product Logs" action="action_orca_ecommerce_log" parent="website_sale.website_sale_menu"/>
    </data>
</odoo>
