<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View: Report ORCA Logs -->
    <record id="report_orca_log_view_tree" model="ir.ui.view">
        <field name="name">l10n.do.accounting.report.orca.log.tree</field>
        <field name="model">l10n.do.accounting.report.orca.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date" widget="date" />
                <field name="action" />
                <field name="report_type" />
                <field name="report_period" />
                <field name="submission_status" />
                <field name="user_id" />
                <field name="orca_synced" widget="boolean" />
            </tree>
        </field>
    </record>

    <!-- Form View: Report ORCA Log Details -->
    <record id="report_orca_log_view_form" model="ir.ui.view">
        <field name="name">l10n.do.accounting.report.orca.log.form</field>
        <field name="model">l10n.do.accounting.report.orca.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="action" />
                            <span> — </span>
                            <field name="report_type" />
                            <span> (</span>
                            <field name="report_period" />
                            <span>)</span>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="record_id" readonly="1" />
                            <field name="action" readonly="1" />
                            <field name="user_id" readonly="1" />
                        </group>
                        <group>
                            <field name="date" readonly="1" />
                            <field name="report_type" readonly="1" />
                            <field name="report_period" readonly="1" />
                        </group>
                    </group>

                    <group string="Submission Status">
                        <group>
                            <field name="submission_status" readonly="1" />
                            <field name="dgii_receipt_id" readonly="1" />
                        </group>
                    </group>

                    <group string="Changes">
                        <field name="before_values" widget="text" readonly="1" />
                        <field name="after_values" widget="text" readonly="1" />
                    </group>

                    <group string="ORCA Sync Status">
                        <group>
                            <field name="orca_synced" readonly="1" />
                            <field name="orca_sync_date" readonly="1" />
                            <field name="orca_request_id" readonly="1" />
                        </group>
                        <group>
                            <field name="orca_sync_error" readonly="1" nolabel="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View: Report ORCA Log Filters -->
    <record id="report_orca_log_view_search" model="ir.ui.view">
        <field name="name">l10n.do.accounting.report.orca.log.search</field>
        <field name="model">l10n.do.accounting.report.orca.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="report_type" />
                <field name="report_period" />
                <field name="submission_status" />
                <field name="user_id" />
                <field name="date" />

                <filter name="filter_created" string="Created" domain="[('action', '=', 'create')]" />
                <filter name="filter_modified" string="Modified" domain="[('action', '=', 'write')]" />

                <separator />

                <filter name="filter_pending" string="Pending Submission" domain="[('submission_status', '=', 'pending')]" />
                <filter name="filter_submitted" string="Submitted" domain="[('submission_status', '=', 'submitted')]" />
                <filter name="filter_accepted" string="Accepted" domain="[('submission_status', '=', 'accepted')]" />
                <filter name="filter_rejected" string="Rejected" domain="[('submission_status', '=', 'rejected')]" />

                <separator />

                <filter name="filter_orca_pending" string="ORCA Pending" domain="[('orca_synced', '=', False)]" />
                <filter name="filter_orca_synced" string="ORCA Synced" domain="[('orca_synced', '=', True)]" />

                <separator />

                <filter name="filter_this_month" string="This Month" domain="[('date', '&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d'))]" />
                <filter name="filter_last_month" string="Last Month" domain="[('date', '&lt;', context_today().replace(day=1).strftime('%Y-%m-%d')), ('date', '&gt;=', (context_today().replace(day=1) - relativedelta(months=1)).strftime('%Y-%m-%d'))]" />

                <group expand="0" string="Group By">
                    <filter name="group_by_report_type" string="Report Type" domain="[]" context="{'group_by': 'report_type'}" />
                    <filter name="group_by_period" string="Period" domain="[]" context="{'group_by': 'report_period'}" />
                    <filter name="group_by_status" string="Status" domain="[]" context="{'group_by': 'submission_status'}" />
                    <filter name="group_by_user" string="User" domain="[]" context="{'group_by': 'user_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="report_orca_log_action" model="ir.actions.act_window">
        <field name="name">Accounting Report ORCA Logs</field>
        <field name="res_model">l10n.do.accounting.report.orca.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="report_orca_log_view_search" />
        <field name="help">ORCA audit logs for report operations. Track all DGII submissions.</field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="report_orca_log_menu"
        name="Report Audit Logs"
        parent="account.menu_finance_reports"
        action="report_orca_log_action"
        sequence="110"
    />
</odoo>
