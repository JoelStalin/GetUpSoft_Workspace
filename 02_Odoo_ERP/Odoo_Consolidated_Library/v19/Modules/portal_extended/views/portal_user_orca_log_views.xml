<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_orca_portal_user_log_tree" model="ir.ui.view">
            <field name="name">Portal User ORCA Log Tree</field>
            <field name="model">orca.portal.user.log</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="date"/>
                    <field name="user_id"/>
                    <field name="action"/>
                    <field name="partner_name"/>
                    <field name="user_email"/>
                    <field name="portal_access"/>
                    <field name="access_level"/>
                </tree>
            </field>
        </record>

        <record id="view_orca_portal_user_log_form" model="ir.ui.view">
            <field name="name">Portal User ORCA Log Form</field>
            <field name="model">orca.portal.user.log</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group string="Log Metadata">
                                <field name="date"/>
                                <field name="user_id"/>
                                <field name="action"/>
                            </group>
                            <group string="Portal User Details">
                                <field name="partner_name"/>
                                <field name="user_email"/>
                                <field name="portal_access"/>
                                <field name="access_level"/>
                                <field name="last_login"/>
                            </group>
                        </group>
                        <group string="Audit Data">
                            <field name="before_values" widget="ace" options="{'mode': 'json'}" nolabel="1"/>
                            <field name="after_values" widget="ace" options="{'mode': 'json'}" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_orca_portal_user_log" model="ir.actions.act_window">
            <field name="name">Portal User ORCA Logs</field>
            <field name="res_model">orca.portal.user.log</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_orca_portal_user_log" name="Portal User Logs" action="action_orca_portal_user_log" parent="portal.portal_config_menu"/>
    </data>
</odoo>
