<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ORCA API Configuration Parameters -->
        <record id="orca_api_url" model="ir.config_parameter">
            <field name="key">orca.api.url</field>
            <field name="value"></field>
        </record>

        <record id="orca_api_key" model="ir.config_parameter">
            <field name="key">orca.api.key</field>
            <field name="value"></field>
        </record>

        <record id="orca_enabled" model="ir.config_parameter">
            <field name="key">orca.enabled</field>
            <field name="value">True</field>
        </record>

        <!-- EasyCount API Configuration Parameters -->
        <record id="easycount_api_url" model="ir.config_parameter">
            <field name="key">easycount.api.url</field>
            <field name="value"></field>
        </record>

        <record id="easycount_api_key" model="ir.config_parameter">
            <field name="key">easycount.api.key</field>
            <field name="value"></field>
        </record>

        <record id="easycount_enabled" model="ir.config_parameter">
            <field name="key">easycount.enabled</field>
            <field name="value">False</field>
        </record>

        <!-- ORCA Logging Configuration -->
        <record id="orca_log_level" model="ir.config_parameter">
            <field name="key">orca.log.level</field>
            <field name="value">INFO</field>
        </record>

        <record id="orca_log_max_records" model="ir.config_parameter">
            <field name="key">orca.log.max_records</field>
            <field name="value">10000</field>
        </record>
    </data>
</odoo>
