<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Department ORCA Log List View -->
    <record id="view_orca_department_log_tree" model="ir.ui.view">
        <field name="name">orca.department.log.list</field>
        <field name="model">orca.department.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="department_name"/>
                <field name="department_code"/>
                <field name="manager_name"/>
                <field name="employee_count"/>
            </tree>
        </field>
    </record>

    <!-- Department ORCA Log Form View -->
    <record id="view_orca_department_log_form" model="ir.ui.view">
        <field name="name">orca.department.log.form</field>
        <field name="model">orca.department.log</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Log Metadata">
                        <field name="module_name"/>
                        <field name="model_name"/>
                        <field name="record_id"/>
                        <field name="action"/>
                        <field name="date"/>
                        <field name="user_id"/>
                    </group>
                    <group string="Department Details">
                        <field name="department_name"/>
                        <field name="department_code"/>
                        <field name="parent_department"/>
                        <field name="manager_name"/>
                        <field name="employee_count"/>
                        <field name="department_status"/>
                    </group>
                    <group string="Audit Data">
                        <field name="before_values" widget="ace"/>
                        <field name="after_values" widget="ace"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_orca_hr_org_logs" name="ORCA Logs" parent="hr.menu_hr_configuration"/>

    <menuitem id="menu_orca_department_log" name="Department Logs"
              parent="menu_orca_hr_org_logs"
              action="action_view_orca_department_log"/>

    <!-- Actions -->
    <act_window id="action_view_orca_department_log"
                name="Department ORCA Logs"
                res_model="orca.department.log"
                view_mode="tree,form"/>
</odoo>
