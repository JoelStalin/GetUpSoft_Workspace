<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Payslip ORCA Log List View -->
    <record id="view_orca_payslip_log_tree" model="ir.ui.view">
        <field name="name">orca.payslip.log.list</field>
        <field name="model">orca.payslip.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="payslip_name"/>
                <field name="employee_name"/>
                <field name="payslip_status"/>
                <field name="gross_amount"/>
            </tree>
        </field>
    </record>

    <!-- Payslip ORCA Log Form View -->
    <record id="view_orca_payslip_log_form" model="ir.ui.view">
        <field name="name">orca.payslip.log.form</field>
        <field name="model">orca.payslip.log</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Log Metadata">
                        <field name="module_name"/>
                        <field name="model_name"/>
                        <field name="record_id"/>
                        <field name="action"/>
                        <field name="date"/>
                        <field name="user_id"/>
                    </group>
                    <group string="Payslip Details">
                        <field name="payslip_name"/>
                        <field name="employee_name"/>
                        <field name="payslip_status"/>
                        <field name="payroll_period"/>
                        <field name="basic_salary"/>
                        <field name="gross_amount"/>
                        <field name="deductions"/>
                        <field name="net_amount"/>
                    </group>
                    <group string="Audit Data">
                        <field name="before_values" widget="ace"/>
                        <field name="after_values" widget="ace"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_orca_payroll_logs" name="ORCA Logs" parent="hr_payroll.menu_hr_payroll_root"/>

    <menuitem id="menu_orca_payslip_log" name="Payslip Logs"
              parent="menu_orca_payroll_logs"
              action="action_view_orca_payslip_log"/>

    <!-- Actions -->
    <act_window id="action_view_orca_payslip_log"
                name="Payslip ORCA Logs"
                res_model="orca.payslip.log"
                view_mode="tree,form"/>
</odoo>
