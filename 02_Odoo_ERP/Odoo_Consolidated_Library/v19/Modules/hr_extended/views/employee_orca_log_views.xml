<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Employee ORCA Log List View -->
    <record id="view_orca_employee_log_tree" model="ir.ui.view">
        <field name="name">orca.employee.log.list</field>
        <field name="model">orca.employee.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="employee_name"/>
                <field name="employee_email"/>
                <field name="employee_status"/>
                <field name="job_title"/>
            </tree>
        </field>
    </record>

    <!-- Employee ORCA Log Form View -->
    <record id="view_orca_employee_log_form" model="ir.ui.view">
        <field name="name">orca.employee.log.form</field>
        <field name="model">orca.employee.log</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Log Metadata">
                        <field name="module_name"/>
                        <field name="model_name"/>
                        <field name="record_id"/>
                        <field name="action"/>
                        <field name="date"/>
                        <field name="user_id"/>
                    </group>
                    <group string="Employee Details">
                        <field name="employee_name"/>
                        <field name="employee_email"/>
                        <field name="employee_status"/>
                        <field name="job_title"/>
                        <field name="department_name"/>
                        <field name="manager_name"/>
                        <field name="contract_status"/>
                    </group>
                    <group string="Audit Data">
                        <field name="before_values" widget="ace"/>
                        <field name="after_values" widget="ace"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_orca_hr_logs" name="ORCA Logs" parent="hr.menu_hr_configuration"/>

    <menuitem id="menu_orca_employee_log" name="Employee Logs"
              parent="menu_orca_hr_logs"
              action="action_view_orca_employee_log"/>

    <!-- Actions -->
    <act_window id="action_view_orca_employee_log"
                name="Employee ORCA Logs"
                res_model="orca.employee.log"
                view_mode="tree,form"/>
</odoo>
