<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ORCA Log List View -->
        <record id="view_accounting_report_orca_log_tree" model="ir.ui.view">
            <field name="name">orca.l10n.do.accounting.report.log.tree</field>
            <field name="model">orca.l10n.do.accounting.report.log</field>
            <field name="arch" type="xml">
                <tree string="Accounting Report ORCA Audit Log" create="false" edit="false" delete="false">
                    <field name="date" string="Date"/>
                    <field name="user_id" string="User"/>
                    <field name="record_id" string="Record ID"/>
                    <field name="action" string="Action"/>
                    <field name="report_type" string="Report Type"/>
                    <field name="date_from" string="From"/>
                    <field name="date_to" string="To"/>
                    <field name="record_count" string="Records"/>
                    <field name="orca_synced" string="ORCA Synced"/>
                </tree>
            </field>
        </record>

        <!-- ORCA Log Form View -->
        <record id="view_accounting_report_orca_log_form" model="ir.ui.view">
            <field name="name">orca.l10n.do.accounting.report.log.form</field>
            <field name="model">orca.l10n.do.accounting.report.log</field>
            <field name="arch" type="xml">
                <form string="Accounting Report ORCA Audit Log" create="false" edit="false" delete="false">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="id"/>
                                <span class="oe_read_only">-</span>
                                <field name="action" class="oe_inline"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="user_id"/>
                                <field name="module_name"/>
                                <field name="model_name"/>
                            </group>
                            <group>
                                <field name="record_id"/>
                                <field name="report_type"/>
                                <field name="record_count"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                            <group>
                                <field name="orca_synced"/>
                                <field name="orca_request_id"/>
                            </group>
                        </group>
                        <separator string="Values"/>
                        <group>
                            <field name="before_values" widget="text" nolabel="1"/>
                        </group>
                        <group>
                            <field name="after_values" widget="text" nolabel="1"/>
                        </group>
                        <separator string="ORCA Sync Status"/>
                        <group>
                            <field name="orca_sync_error" widget="text" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_accounting_report_orca_log_search" model="ir.ui.view">
            <field name="name">orca.l10n.do.accounting.report.log.search</field>
            <field name="model">orca.l10n.do.accounting.report.log</field>
            <field name="arch" type="xml">
                <search string="Accounting Report ORCA Audit Log">
                    <field name="record_id"/>
                    <field name="report_type"/>
                    <field name="user_id"/>
                    <field name="date"/>
                    <filter name="synced" string="Synced to ORCA" domain="[('orca_synced', '=', True)]"/>
                    <filter name="not_synced" string="Not Synced" domain="[('orca_synced', '=', False)]"/>
                    <filter name="errors" string="With Errors" domain="[('orca_sync_error', '!=', False)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_action" string="Action" domain="[]" context="{'group_by': 'action'}"/>
                        <filter name="group_by_report_type" string="Report Type" domain="[]" context="{'group_by': 'report_type'}"/>
                        <filter name="group_by_user" string="User" domain="[]" context="{'group_by': 'user_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_accounting_report_orca_log" model="ir.actions.act_window">
            <field name="name">Accounting Report ORCA Audit Log</field>
            <field name="res_model">orca.l10n.do.accounting.report.log</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_accounting_report_orca_log_search"/>
        </record>

        <!-- Menu Item -->
        <menuitem
            id="menu_accounting_report_orca_log"
            parent="l10n_do_accounting.menu_dgii_reports"
            name="Report ORCA Audit Log"
            action="action_accounting_report_orca_log"
            sequence="55"
        />
    </data>
</odoo>
