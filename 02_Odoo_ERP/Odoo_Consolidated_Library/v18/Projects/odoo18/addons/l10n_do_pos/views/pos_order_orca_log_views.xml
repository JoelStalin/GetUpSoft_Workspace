<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View: POS Order ORCA Logs -->
    <record id="pos_order_orca_log_view_tree" model="ir.ui.view">
        <field name="name">l10n.do.pos.orca.log.tree</field>
        <field name="model">l10n.do.pos.orca.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date" widget="date" />
                <field name="action" />
                <field name="pos_reference" />
                <field name="amount_total" />
                <field name="fiscal_status" />
                <field name="user_id" />
                <field name="orca_synced" widget="boolean" />
            </tree>
        </field>
    </record>

    <!-- Form View: POS Order ORCA Log Details -->
    <record id="pos_order_orca_log_view_form" model="ir.ui.view">
        <field name="name">l10n.do.pos.orca.log.form</field>
        <field name="model">l10n.do.pos.orca.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="action" />
                            <span> — </span>
                            <field name="pos_reference" />
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="record_id" readonly="1" />
                            <field name="action" readonly="1" />
                            <field name="user_id" readonly="1" />
                        </group>
                        <group>
                            <field name="date" readonly="1" />
                            <field name="pos_reference" readonly="1" />
                            <field name="amount_total" readonly="1" />
                        </group>
                    </group>

                    <group string="Fiscal Status">
                        <group>
                            <field name="fiscal_status" readonly="1" />
                            <field name="payment_method" readonly="1" />
                        </group>
                    </group>

                    <group string="Changes">
                        <field name="before_values" widget="text" readonly="1" />
                        <field name="after_values" widget="text" readonly="1" />
                    </group>

                    <group string="ORCA Sync Status">
                        <group>
                            <field name="orca_synced" readonly="1" />
                            <field name="orca_sync_date" readonly="1" />
                            <field name="orca_request_id" readonly="1" />
                        </group>
                        <group>
                            <field name="orca_sync_error" readonly="1" nolabel="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View: POS Order ORCA Log Filters -->
    <record id="pos_order_orca_log_view_search" model="ir.ui.view">
        <field name="name">l10n.do.pos.orca.log.search</field>
        <field name="model">l10n.do.pos.orca.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="pos_reference" />
                <field name="fiscal_status" />
                <field name="user_id" />
                <field name="date" />

                <filter name="filter_created" string="Created" domain="[('action', '=', 'create')]" />
                <filter name="filter_modified" string="Modified" domain="[('action', '=', 'write')]" />

                <separator />

                <filter name="filter_pending" string="Pending" domain="[('fiscal_status', '=', 'pending')]" />
                <filter name="filter_confirmed" string="Confirmed" domain="[('fiscal_status', '=', 'confirmed')]" />
                <filter name="filter_cancelled" string="Cancelled" domain="[('fiscal_status', '=', 'cancelled')]" />

                <separator />

                <filter name="filter_orca_pending" string="ORCA Pending" domain="[('orca_synced', '=', False)]" />
                <filter name="filter_orca_synced" string="ORCA Synced" domain="[('orca_synced', '=', True)]" />

                <group expand="0" string="Group By">
                    <filter name="group_by_fiscal" string="Fiscal Status" domain="[]" context="{'group_by': 'fiscal_status'}" />
                    <filter name="group_by_user" string="User" domain="[]" context="{'group_by': 'user_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="pos_order_orca_log_action" model="ir.actions.act_window">
        <field name="name">POS Order ORCA Logs</field>
        <field name="res_model">l10n.do.pos.orca.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="pos_order_orca_log_view_search" />
        <field name="help">ORCA audit logs for POS operations. Track all point of sale transactions.</field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="pos_order_orca_log_menu"
        name="POS Audit Logs"
        parent="point_of_sale.menu_point_root"
        action="pos_order_orca_log_action"
        sequence="50"
    />
</odoo>
