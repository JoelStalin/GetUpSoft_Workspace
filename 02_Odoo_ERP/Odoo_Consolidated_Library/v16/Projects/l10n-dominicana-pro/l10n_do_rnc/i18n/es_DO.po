msgstr "El contacto %s ya existe con el %s: %s."

#. module: l10n_do_rnc
#. odoo-python
#: code:addons/l10n_do_rnc/models/res_partner.py:0
#, python-format
msgid "The entered RNC/ID is not valid."
msgstr "El RNC/ID introducido no es válido."

#. module: l10n_do_rnc
#. odoo-python
#: code:addons/l10n_do_rnc/models/res_partner.py:0
#, python-format
msgid ""
"This RNC or Cedula (%s) could not be found, please confirm the RNC or "
"Cedula number.                            If it is a system search error, "
"enter manually the full company name and the RNC / "
"Cedula                             in the field labeled RNC for companies "
"and Cedula for individuals for force create the contact."
msgstr ""
"No se ha encontrado este RNC o Cedula (%s), por favor confirme el número de "
"RNC o Cedula.                            Si se trata de un error de "
"búsqueda del sistema, introduzca manualmente el nombre completo de la "
"empresa y el RNC / Cedula en el campo RNC para empresas y Cedula para "
"particulares para forzar la creación del contacto."

#. module: l10n_do_rnc
#: model_terms:ir.ui.view,arch_db:l10n_do_rnc.view_res_partner_form
