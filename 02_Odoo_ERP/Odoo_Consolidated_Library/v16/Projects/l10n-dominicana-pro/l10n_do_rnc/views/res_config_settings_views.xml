<odoo>
    
    <!-- View res.config.settings form -->
    <record id="view_res_config_settings_form_inherit_rnc" model="ir.ui.view">
        <field name="name">view.res.config.settings.form.inherit.rnc</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='languages']" position="before">
                <div id="rnc_service_search">
                    <h2>RNC Service Search</h2>
                    <div class="row mt16 o_settings_container" name="rnc_service_search_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">RNC Service</span>
                                <div class="text-muted">
                                    Select the RNC Service search you want to use.
                                </div>
                                <br/>
                                <div class="content-group">
                                    <div class="row align-items-baseline">
                                        <!-- Field rnc_service -->
                                        <div class="col-8">
                                            <div class="row align-items-baseline">
                                                <div class="col-8">
                                                    <label for="l10n_do_rnc_service" string="RNC Service" class="o_light_label"/>
                                                </div>
                                                <div class="col-4">
                                                    <field name="l10n_do_rnc_service" class="oe_inline"/>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Field api_key -->
                                        <div class="col-8" attrs="{'invisible': [('l10n_do_rnc_service', '!=', 'jenrax')]}" name="jenrax_api_key">
                                            <div class="row align-items-baseline">
                                                <div class="col-8">
                                                    <label for="l10n_do_rnc_jenrax_api_key" string="Jenrax RNC API key" class="o_light_label"/>
                                                </div>
                                                <div class="col-4">
                                                    <field name="l10n_do_rnc_jenrax_api_key" class="oe_inline" attrs="{'required':[('l10n_do_rnc_service', '=', 'jenrax')]}"/>
                                                </div>
                                                <div class="col-12">
                                                    <a href="https://jenrax.com" target="_blank">Get your API Key</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>