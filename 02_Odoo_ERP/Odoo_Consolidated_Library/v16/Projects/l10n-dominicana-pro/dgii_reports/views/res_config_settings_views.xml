<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_inherit_dgii" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.dgii</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@data-key='account']" position="inside">
                <h2>DGII</h2>
                <div class="row mt16 o_settings_container" name="default_taxes_setting_container">
                    <div class="col-12 col-lg-6 o_setting_box" id="l10n_do_is_subject_to_proportionality" title="Subject to Proportionality" groups="account.group_account_user">
                        <div class="o_setting_left_pane">
                            <field name="l10n_do_is_subject_to_proportionality" readonly="0"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="l10n_do_is_subject_to_proportionality"/>
                            <span class="fa fa-lg fa-balance-scale" title="Subject to Proportionality" aria-label="Subject to Proportionality" role="img"/>
                            <div class="text-muted">
                                All purchase invoices will be subject to proportionality.
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>