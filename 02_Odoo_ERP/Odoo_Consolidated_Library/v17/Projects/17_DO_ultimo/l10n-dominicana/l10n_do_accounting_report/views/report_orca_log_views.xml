<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_orca_log_view_tree" model="ir.ui.view">
        <field name="name">l10n.do.accounting.report.orca.log.tree</field>
        <field name="model">l10n.do.accounting.report.orca.log</field>
        <field name="arch" type="xml">
            <tree><field name="date" widget="date" /><field name="action" /><field name="report_type" /><field name="submission_status" /><field name="user_id" /><field name="orca_synced" widget="boolean" /></tree>
        </field>
    </record>

    <record id="report_orca_log_view_form" model="ir.ui.view">
        <field name="name">l10n.do.accounting.report.orca.log.form</field>
        <field name="model">l10n.do.accounting.report.orca.log</field>
        <field name="arch" type="xml">
            <form><sheet><div class="oe_title"><h1><field name="action" /> — <field name="report_type" /></h1></div><group><group><field name="record_id" readonly="1" /><field name="action" readonly="1" /></group></group><group string="Submission Status"><field name="submission_status" readonly="1" /><field name="dgii_receipt_id" readonly="1" /></group><group string="ORCA Sync Status"><group><field name="orca_synced" readonly="1" /><field name="orca_sync_date" readonly="1" /></group></group></sheet></form>
        </field>
    </record>

    <record id="report_orca_log_action" model="ir.actions.act_window">
        <field name="name">Report ORCA Logs</field>
        <field name="res_model">l10n.do.accounting.report.orca.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="report_orca_log_menu" name="Report Audit Logs" parent="account.menu_finance_reports" action="report_orca_log_action" sequence="110" />
</odoo>
