<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Template QWeb para el Reporte PDF -->
    <template id="report_accounting_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Encabezado -->
                        <div class="text-center">
                            <h2>REPORTE CONTABLE PERSONALIZADO</h2>
                            <h4 t-field="wizard.company_id.name"/>
                            <p>
                                <strong>Período:</strong>
                                <span t-field="wizard.date_from"/> - <span t-field="wizard.date_to"/>
                            </p>
                        </div>
                        
                        <!-- Filtros aplicados -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <p><strong>Estado:</strong>
                                    <t t-if="wizard.target_move == 'posted'">Publicados</t>
                                    <t t-else="">Todos</t>
                                </p>
                            </div>
                            <div class="col-6">
                                <p><strong>Tipo:</strong>
                                    <t t-if="wizard.move_type == 'all'">Todos</t>
                                    <t t-elif="wizard.move_type == 'entry'">Asientos</t>
                                    <t t-elif="wizard.move_type == 'out_invoice'">Facturas Cliente</t>
                                    <t t-elif="wizard.move_type == 'in_invoice'">Facturas Proveedor</t>
                                    <t t-else=""><t t-esc="wizard.move_type"/></t>
                                </p>
                            </div>
                        </div>
                        
                        <!-- Tabla de datos -->
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr class="bg-primary text-white">
                                    <th>Fecha</th>
                                    <th>Diario</th>
                                    <th>Número</th>
                                    <th>Cuenta</th>
                                    <th>Partner</th>
                                    <th>Etiqueta</th>
                                    <th class="text-right">Débito</th>
                                    <th class="text-right">Crédito</th>
                                    <th class="text-right">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="wizard.line_ids" t-as="line">
                                    <tr>
                                        <td t-field="line.date"/>
                                        <td t-esc="line.journal_name"/>
                                        <td t-esc="line.move_name"/>
                                        <td>
                                            <t t-esc="line.account_code"/> - <t t-esc="line.account_name"/>
                                        </td>
                                        <td t-esc="line.partner_name"/>
                                        <td t-esc="line.name"/>
                                        <td class="text-right" t-field="line.debit" 
                                            t-options='{"widget": "monetary", "display_currency": line.currency_id}'/>
                                        <td class="text-right" t-field="line.credit"
                                            t-options='{"widget": "monetary", "display_currency": line.currency_id}'/>
                                        <td class="text-right" t-field="line.balance"
                                            t-options='{"widget": "monetary", "display_currency": line.currency_id}'/>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr class="bg-light font-weight-bold">
                                    <td colspan="6" class="text-right"><strong>TOTALES:</strong></td>
                                    <td class="text-right" t-field="wizard.total_debit"
                                        t-options='{"widget": "monetary", "display_currency": wizard.currency_id}'/>
                                    <td class="text-right" t-field="wizard.total_credit"
                                        t-options='{"widget": "monetary", "display_currency": wizard.currency_id}'/>
                                    <td class="text-right" t-field="wizard.total_balance"
                                        t-options='{"widget": "monetary", "display_currency": wizard.currency_id}'/>
                                </tr>
                            </tfoot>
                        </table>
                        
                        <!-- Pie de página con información -->
                        <div class="row mt-4">
                            <div class="col-6">
                                <p><small>
                                    <strong>Total de registros:</strong> 
                                    <t t-esc="len(wizard.line_ids)"/>
                                </small></p>
                            </div>
                            <div class="col-6 text-right">
                                <p><small>
                                    <strong>Generado:</strong> 
                                    <t t-esc="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/>
                                </small></p>
                            </div>
                        </div>
                        
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
