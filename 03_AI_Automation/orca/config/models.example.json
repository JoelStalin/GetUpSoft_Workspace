{
  "default_model": "deepseek-v4-pro",
  "models": [
    {
      "id": "deepseek-v4-pro",
      "provider": "nvidia-openai-compatible",
      "model": "deepseek-ai/deepseek-v4-pro",
      "base_url": "https://integrate.api.nvidia.com/v1",
      "api_key_env": "NVIDIA_API_KEY",
      "default_params": {
        "temperature": 0.2,
        "top_p": 0.95,
        "max_tokens": 4096
      },
      "extra_body": {
        "chat_template_kwargs": {
          "thinking": false
        }
      }
    },
