      ]
    },
    {
      "name": "DGII ENFC",
      "item": [
        {
          "name": "Semilla (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/fe/autenticacion/api/semilla",
              "host": ["{{base_url}}"],
              "path": ["fe", "autenticacion", "api", "semilla"]
            }
          }
        },
        {
          "name": "Validacion Certificado (XML firmado => token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/fe/autenticacion/api/validacioncertificado",
              "host": ["{{base_url}}"],
              "path": ["fe", "autenticacion", "api", "validacioncertificado"]
            },
            "body": { "mode": "raw", "raw": "{{semilla_signed_xml}}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) { pm.collectionVariables.set('enfc_token', json.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Recepcion e-CF",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{enfc_token}}" },
              { "key": "Idempotency-Key", "value": "demo-1" }
            ],
            "url": {
              "raw": "{{base_url}}/fe/recepcion/api/ecf",
              "host": ["{{base_url}}"],
              "path": ["fe", "recepcion", "api", "ecf"]
            },
            "body": { "mode": "raw", "raw": "{{ecf_xml}}" }
          }
        },
        {
          "name": "Aprobacion Comercial (ACECF)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{enfc_token}}" },
              { "key": "Idempotency-Key", "value": "demo-2" }
            ],
            "url": {
              "raw": "{{base_url}}/fe/aprobacioncomercial/api/ecf",
              "host": ["{{base_url}}"],
              "path": ["fe", "aprobacioncomercial", "api", "ecf"]
            },
            "body": { "mode": "raw", "raw": "{{acecf_xml}}" }
          }
        }
      ]
    }
  ]
}
