<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="getupsoft_l10n_do_pos_inherit_pos_config_view_form" model="ir.ui.view">
        <field name="name">getupsoft_l10n_do_pos.config.view.form</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <field name="active" position="after">
                <field name="l10n_latam_use_documents" invisible="1"/>
                <field name="l10n_latam_country_code" invisible="1"/>
            </field>

            <xpath expr="//div[@id='iface_invoicing']//div[2]//div[2]">
                <div class="row mt16"
                      invisible="(l10n_latam_use_documents == False or l10n_latam_country_code != 'DO')">
                    <label string="Default customer" for="l10n_do_default_partner_id"
                        class="col-md-3 o_light_label"/>
                    <field name="l10n_do_default_partner_id"
                         required="(module_account == True) and (l10n_latam_use_documents == True)"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
