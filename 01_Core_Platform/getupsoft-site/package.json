{
  "name": "getupsoft-corporate-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "preview:edge": "vite preview --host 0.0.0.0 --port 18085",
    "flow:prepare": "node scripts/flow-assets.mjs prepare",
    "flow:checklist": "node scripts/flow-assets.mjs checklist",
    "flow:check": "node scripts/flow-assets.mjs check",
    "stitch:dry-run": "npm --prefix stitch run dry-run",
    "stitch:generate": "npm --prefix stitch run generate",
    "stitch:generate:global": "npm --prefix stitch run generate:global",
    "stitch:generate:rd": "npm --prefix stitch run generate:rd",
    "stitch:manifest": "node scripts/stitch-output-manifest.mjs",
    "test": "echo 'Run test:e2e commands below'",
    "test:e2e": "npm run test:e2e:selenium",
    "test:e2e:selenium": "python tests/e2e/getupsoft_site_functional.py",
    "test:smoke": "bash tests/smoke-tests.sh",
    "test:lighthouse": "lighthouse http://localhost:5176/redesign/ --view",
    "test:accessibility": "echo 'Run manual accessibility audit with axe DevTools extension'",
    "test:security": "npm audit && echo 'Run manual security tests'"
  },
  "dependencies": {
    "animejs": "^4.4.1",
    "next-intl": "^4.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/animejs": "^3.1.13",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
