# GetUpSoft Site Environment Variables
# Copy this file to .env.production for production deployment
# Copy this file to .env.development for local development

# ========================================
# ERP Configuration
# ========================================

# ERP Type: "mock" or "odoo"
VITE_ERP_TYPE=mock

# Odoo Configuration (production)
VITE_ODOO_HOST=your-odoo-instance.com
VITE_ODOO_PORT=8069
VITE_ODOO_DATABASE=production_db
VITE_ODOO_USERNAME=api_user
VITE_ODOO_PASSWORD=secure_password

# ERP Behavior Flags
VITE_USE_MOCK=false
VITE_AUTO_CONNECT_ERP=true
VITE_DISABLE_ERP=false

# ========================================
# Email Configuration
# ========================================

# Email Provider Type
VITE_USE_MOCK_EMAIL=false

# SMTP Configuration (production)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_SECURE=false
VITE_SMTP_USER=noreply@company.com
VITE_SMTP_PASS=your-app-password
VITE_SMTP_FROM=noreply@company.com

# Email Behavior
VITE_DISABLE_EMAIL=false

# ========================================
# Application Configuration
# ========================================

# Node Environment
NODE_ENV=production

# Debug Mode
VITE_DEBUG=false

# ========================================
# Deployment & Infrastructure
# ========================================

# Docker
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=getupsoft-site
DOCKER_IMAGE_TAG=latest

# Kubernetes (if using K8s)
K8S_NAMESPACE=default
K8S_DEPLOYMENT_NAME=getupsoft-site

# ========================================
# Monitoring & Observability
# ========================================

# Sentry (Error Tracking)
VITE_SENTRY_DSN=https://key@sentry.io/project
VITE_SENTRY_ENVIRONMENT=production

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Log Level
LOG_LEVEL=info
