# SMTP modular para notificaciones y workflows internos
# OpciÃ³n 1: Mailpit (Open Source - Docker) - RECOMENDADO PARA DESARROLLO
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@getupsoft.com.do
SMTP_TIMEOUT_SECONDS=20

# Nota: Para usar servicios externos en vez de Mailpit:
# SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=SG.xxx
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=tu@gmail.com SMTP_PASS=app-password
# AWS SES: SMTP_HOST=email-smtp.region.amazonaws.com SMTP_PORT=587 SMTP_USER=xxx SMTP_PASS=xxx

